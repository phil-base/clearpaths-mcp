# Clearpaths API base URL
CLEARPATHS_URL=https://app.clearpaths.pro

# --- Stdio mode (default) ---
# Single-user token from env
CLEARPATHS_TOKEN=your-api-token-here

# --- HTTP mode ---
# Set TRANSPORT=http to run as a remote MCP server.
# Each connecting client provides their own token via Authorization header.
# TRANSPORT=http
# PORT=3001
